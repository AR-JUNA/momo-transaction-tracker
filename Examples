"_info": {
"title": "MoMo SMS Data Processing System - JSON Schemas",
"description": "This file shows how each database table maps to JSON. We use these structures in our FastAPI endpoints to send data to the frontend dashboard.",
"version": "1.0",
"note": "All amounts are in RWF (Rwandan Franc). Timestamps are ISO 8601 format."
},

"_sql_to_json_mapping": {
"transaction_categories table": "TransactionCategory object",
"users table": "User object",
"wallets table": "Wallet object - nested inside User in full responses",
"agents table": "Agent object - nested inside User when account_type is AGENT",
"merchants table": "Merchant object - nested inside User when account_type is MERCHANT",
"sms_raw_messages table": "SmsMessage object - nested as source_sms inside Transaction",
"transactions table": "Transaction object - flat with FK ids for lists, fully nested for detail view",
"tags table": "Tag object",
"transaction_tags table": "Junction resolved - shown as tags array inside Transaction",
"system_logs table": "SystemLog object - references sms, transaction and user as small summaries"
},

