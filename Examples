"sql_to_json_mapping_explained": {
"_description": "This section documents exactly how each SQL table and column maps to a JSON field. This is important because the database stores data in separate tables using foreign keys, but the API needs to return everything in one connected object.",

"table_mappings": [
{
"sql_table": "transaction_categories",
"json_representation": "category object nested inside transaction",
"example_sql_columns": ["category_id", "category_name", "description", "requires_agent", "requires_merchant", "created_at"],
"example_json_path": "transaction.category.category_name",
"note": "In the database this is a separate table. In JSON we nest it directly inside the transaction so the API client does not need to make a second request."
},
{
"sql_table": "users",
"json_representation": "sender and receiver objects nested inside transaction",
"example_sql_columns": ["user_id", "phone_number", "full_name", "account_type", "is_active", "created_at", "updated_at"],
"example_json_path": "transaction.sender.full_name and transaction.receiver.full_name",
"note": "The users table is referenced twice in the transactions table - once as sender_id and once as receiver_id. In JSON both become full nested objects."
},
{
"sql_table": "wallets",
"json_representation": "wallet object nested inside sender or receiver",
"example_sql_columns": ["wallet_id", "user_id", "current_balance", "daily_limit", "wallet_status", "last_transaction_at"],
"example_json_path": "transaction.sender.wallet.current_balance",
"note": "Wallets have a 1 to 1 relationship with users. In JSON we nest the wallet inside the user object."
},
{
"sql_table": "agents",
"json_representation": "agent object nested directly inside transaction",
"example_sql_columns": ["agent_id", "user_id", "agent_code", "business_name", "location", "is_verified"],
"example_json_path": "transaction.agent.agent_code",
"note": "Only present when the transaction type is DEPOSIT or WITHDRAWAL. Otherwise this field is null."
},
{
"sql_table": "merchants",
"json_representation": "merchant object nested directly inside transaction",
"example_sql_columns": ["merchant_id", "user_id", "merchant_code", "business_name", "business_category", "settlement_account", "is_verified"],
"example_json_path": "transaction.merchant.merchant_code",
"note": "Only present when the transaction type is MERCHANT_PAYMENT. Otherwise this field is null."
},
{
"sql_table": "sms_raw_messages",
"json_representation": "source_sms object nested inside transaction",
"example_sql_columns": ["sms_id", "message_uid", "raw_body", "parse_status", "failure_reason", "received_at", "processed_at"],
"example_json_path": "transaction.source_sms.raw_body",
"note": "This links the transaction back to the original SMS that created it. Can be null for reversals which are created by the system not by an SMS."
},
{
"sql_table": "transactions (self-referencing FK)",
"json_representation": "reversal_of object nested inside transaction",
"example_sql_columns": ["transaction_id", "reference_id", "amount", "transaction_date", "status"],
"example_json_path": "transaction.reversal_of.reference_id",
"note": "This is a special case. The reverses_transaction_id column in the transactions table points back to another row in the same table. In JSON we show just a small summary of the original transaction."
},
{
"sql_table": "tags + transaction_tags (junction)",
"json_representation": "tags array inside transaction",
"example_sql_columns": ["tag_id", "tag_name", "tag_color", "tagged_at", "tagged_by"],
"example_json_path": "transaction.tags[0].tag_name",
"note": "In the database there are two tables here - tags and transaction_tags. The junction table transaction_tags stores the many-to-many relationship. In JSON we resolve this into a simple array of tag objects."
},
{
"sql_table": "system_logs",
"json_representation": "standalone log object with nested sms and transaction summaries",
"example_sql_columns": ["log_id", "sms_id", "transaction_id", "triggered_by", "log_level", "event_type", "message", "source_file", "created_at"],
"example_json_path": "log.related_sms.sms_id and log.related_transaction.reference_id",
"note": "The three FK columns (sms_id, transaction_id, triggered_by) each become a small nested summary object in the JSON response. They are all nullable so can be null when the log is not related to any specific SMS or transaction."
}
],

"data_type_mappings": {
"INT (SQL)": "number (JSON)",
"VARCHAR and TEXT (SQL)": "string (JSON)",
"DECIMAL (SQL)": "number with decimal point (JSON) e.g 8000.00",
"DATETIME (SQL)": "string in ISO 8601 format (JSON) e.g 2024-03-01T09:10:00Z",
"TINYINT 1 or 0 (SQL)": "boolean true or false (JSON)",
"NULL (SQL)": "null (JSON)"
},

"nesting_rules": {
"list_view": "When returning a list of transactions we use flat JSON with FK ids only. This keeps the response small and fast.",
"detail_view": "When returning a single transaction we use fully nested JSON where every FK is replaced with the full related object.",
"always_nested": "category, source_sms and tags are always nested even in list views because they are needed for display.",
"nullable_fields": "agent, merchant and reversal_of are null when not applicable to that transaction type. The API always includes the key but sets the value to null."
}
}
}
